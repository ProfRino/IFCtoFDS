# Diagnostic probe / diagnose scripts written during debugging sessions —
# kept local so the public repo only carries reusable tests + bundle generators.
scripts/probe-*.js
scripts/diagnose-*.js
scripts/check-wall-voids.js

# Demo of a sibling viewer that lived next to this project during development.
